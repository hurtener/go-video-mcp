# Build artifacts
/dist/
/bin/
*.exe
*.test
*.out
coverage.out

# Dockyard / Go
go.work
go.work.sum

# Frontend (MCP App)
web/node_modules/
node_modules/
# web/dist is a Vite build artifact, but keep .gitkeep so //go:embed all:web/dist
# compiles on a fresh clone (before `dockyard build` runs Vite).
web/dist/*
!web/dist/.gitkeep

# Generated media / scratch output from local runs
/output/
/tmp/
/frameline-work/
*.mp4
*.mov
*.mkv
*.webm
*.gif
# keep small test fixtures explicitly via: git add -f testdata/...
!testdata/**

# OS / editor cruft
.DS_Store
*.swp
.idea/
.vscode/
